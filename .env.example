PORT=8080

# Local/dev connection string used by the app.
DB_URL=postgres://postgres:postgres@localhost:5432/gin?sslmode=disable

# Swagger UI base URL (host + scheme).
# PUBLIC_BASE_URL=https://your-app.herokuapp.com
# On Heroku, HEROKU_APP_NAME is set automatically → https://<app>.herokuapp.com if PUBLIC_BASE_URL are unset.